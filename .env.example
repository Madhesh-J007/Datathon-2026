# =============================================================================
# KSP Crime Intelligence Platform - Environment Variables
# Purpose: single source of environment configuration for local dev via
# docker-compose. Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# =============================================================================

# --- PostgreSQL (SAD Section 3.3 / 6.1) ---
POSTGRES_USER=ksp_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ksp_crime_intel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ksp_admin:change_me@postgres:5432/ksp_crime_intel

# --- Redis (cache, sessions, Celery broker - SAD Section 3.3/3.5) ---
REDIS_URL=redis://redis:6379/0

# --- JWT Auth (SAD Section 7.2) ---
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# --- Core Backend service (backend/) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- AI Engine service (ai-engine/) ---
AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8100
AI_ENGINE_BASE_URL=http://ai-engine:8100   # used by Core Backend's services/*.py to call the AI Engine

# --- AI Assistant LLM provider (SAD Section 15.4) ---
LLM_PROVIDER=anthropic
LLM_API_KEY=change_me
LLM_MODEL=claude-sonnet-4-6

# --- Embedding model (MO Similarity Engine, SAD Section 3.4) ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- Object storage (evidence files, generated reports - SAD Section 3.3) ---
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=change_me
OBJECT_STORAGE_SECRET_KEY=change_me
OBJECT_STORAGE_BUCKET=ksp-reports-evidence

# --- Frontend (frontend/) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_MAPBOX_TOKEN=change_me
